        <mxCell id="P1" value="① Trigger-port configuration (declare_services loop, every ~10s)" style="text;html=1;align=left;fontSize=13;fontStyle=1;fontColor=#000000;fillColor=#e3c800;strokeColor=#B09500;" parent="1" vertex="1">
