            <mxPoint x="410" y="710" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s5" value="configure_access_port via rtnetlink&lt;br&gt;peers.insert(VethKey, remote_ip)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="315" y="725" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="m8" value="ack(MsgId)" style="endArrow=classic;html=1;fontSize=11;fontColor=#FFFFFF;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="785" as="sourcePoint" />
            <mxPoint x="130" y="785" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m9" value="VxlanSetup (vxlan_id, ns/br, local_ip, remote_ip, host_mapping, dnat_port)" style="endArrow=classic;html=1;fontSize=11;fontColor=#FFFFFF;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="825" as="sourcePoint" />
            <mxPoint x="410" y="825" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s6" value="run vxlan-setup.sh:&lt;br&gt;create netns + bridge + VXLAN tunnel,&lt;br&gt;optionally attach Docker container" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="315" y="845" width="190" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="add_host_mapping(name → overlay_ip)&lt;br&gt;writes /etc/hosts (host + container)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="315" y="910" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="m10" value="dnat::install(dnat_port, overlay_ip)" style="endArrow=classic;html=1;fontSize=11;fontColor=#FFFFFF;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="975" as="sourcePoint" />
            <mxPoint x="1250" y="975" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s8" value="iptables -t nat -A NULLNET_DNAT&lt;br&gt;-p tcp/udp --dport P&lt;br&gt;-j DNAT --to-destination overlay_ip:P&lt;br&gt;(chain hooked from OUTPUT and PREROUTING)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="1155" y="990" width="190" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="conntrack -D -p tcp/udp --dport P&lt;br&gt;flush stale flows for this port" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="1155" y="1060" width="190" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s10" value="TriggersState.mark_active(port,&lt;br&gt;vxlan_id, overlay_ip)—teardown will reverse" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="315" y="1060" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="m11" value="ack(MsgId)" style="endArrow=classic;html=1;fontSize=11;fontColor=#FFFFFF;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="1115" as="sourcePoint" />
            <mxPoint x="130" y="1115" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="P5" value="⑤ Redirected traffic — app retries (TCP RTO / app-level resend); now DNAT steers it into the overlay" style="text;html=1;align=left;fontSize=13;fontStyle=1;fontColor=#000000;fillColor=#e3c800;strokeColor=#B09500;" parent="1" vertex="1">
          <mxGeometry x="40" y="1145" width="1500" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m12" value="next packet to port P (enters OUTPUT chain pre-routing)" style="endArrow=classic;html=1;fontSize=11;fontColor=#FFFFFF;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="970" y="1185" as="sourcePoint" />
            <mxPoint x="1250" y="1185" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s11" value="DNAT rewrites dst → overlay_ip:P;&lt;br&gt;conntrack records flow for reverse NAT&lt;br&gt;(routed via bridge, not original eth)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="1155" y="1205" width="190" height="55" as="geometry" />
        </mxCell>
