        <mxCell id="s12" value="delivered to backend container&lt;br&gt;in remote namespace" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;fontColor=#000000;" parent="1" vertex="1">
