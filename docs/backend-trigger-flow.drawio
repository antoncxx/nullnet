        </mxCell>
        <mxCell id="P2" value="② Outgoing packet on a watched dependency port" style="text;html=1;align=left;fontSize=13;fontStyle=1;fontColor=#000000;fillColor=#e3c800;strokeColor=#B09500;" parent="1" vertex="1">
          <mxGeometry x="40" y="280" width="800" height="20" as="geometry" />
